# ── Claude Authentication ──────────────────────────────────────
# The SDK runs Claude Code as a subprocess, so it uses whatever
# auth the CLI has. If logged in via `claude` (OAuth), no key needed.
#
# Only set this if using API key auth instead of OAuth:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Third-party providers (set ONE, then configure provider credentials):
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1
# CLAUDE_CODE_USE_FOUNDRY=1

# ── Claude Model ──────────────────────────────────────────────
# If unset, SDK/CLI uses its default model.
# Use aliases or full model IDs.
#
# Aliases (recommended):
#   opus       — most capable (Claude 4.6)
#   sonnet     — balanced    (Claude 4.6)
#   haiku      — fastest     (Claude 4.5)
#
# Full model IDs (Claude 4.6):
#   claude-opus-4-6
#   claude-sonnet-4-6
#
# Note: Older model IDs (e.g. claude-opus-4-5-20250514) may not
# be available with OAuth auth. Use aliases to get the latest.
#
CLAUDE_MODEL=sonnet

# ── Claude Effort (optional) ─────────────────────────────────
# Controls thinking depth: low, medium, high, max
# CLAUDE_EFFORT=high

# ── OpenAI (Track C2) ────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
#
# Models:
#   gpt-4o           — most capable
#   gpt-4o-mini      — fast / cheap
#   o3               — reasoning
#   o4-mini          — reasoning, fast
#
# OPENAI_MODEL=gpt-4o

# ── Zhipu AI / GLM (Track C3) ────────────────────────────────
# Get your key at: https://open.bigmodel.cn/
# ZHIPUAI_API_KEY=your-zhipu-api-key
#
# GLM models: glm-5.1, glm-4.7, glm-4.5-air, glm-4-flash
# GLM_MODEL=glm-4-flash
#
# Z.AI also provides an Anthropic-compatible proxy for Claude Code.
# See phase-c/glm/.claude/settings.json for that setup.
